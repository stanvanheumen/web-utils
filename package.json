{
    "name": "@stanvanheumen/web-utils",
    "version": "1.0.0",
    "description": "Lightweight, type-safe utility functions for web development",
    "keywords": [
        "utils",
        "typescript",
        "web"
    ],
    "license": "MIT",
    "author": {
        "name": "Stan van Heumen",
        "email": "stanvanheumen@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/stanvanheumen/web-utils"
    },
    "bugs": {
        "url": "https://github.com/stanvanheumen/web-utils/issues"
    },
    "homepage": "https://github.com/stanvanheumen/web-utils#readme",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run typecheck && npm run build"
    },
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
}
